generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderSide {
  BUY
  SELL
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  orders  Order[]
  fills   Fill[]
  balance Balance?
}

model Balance {
  id        String @id @default(uuid())
  userId    String
  asset     String // e.g., 'USDT', 'BTC'
  available Float  @default(0)
  locked    Float  @default(0)

  user User @relation(fields: [userId], references: [id])

  // A user can only have one balance record per specific asset
  @@unique([userId, asset])
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  market    String
  price     Float?
  qty       Float
  type      OrderType
  side      OrderSide
  filledQty Float       @default(0)
  status    OrderStatus @default(OPEN)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Fill {
  id              Int       @id @default(autoincrement())
  qty             Float
  side            OrderSide
  type            OrderType
  userId          Int
  price           Float?
  asset           String
  originalOrderId Int

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Stock {
  id     Int    @id @default(autoincrement())
  name   String
  symbol String @unique
}

model Balance {
  id     Int   @id @default(autoincrement())
  userId Int   @unique
  usd    Float @default(0)

  user User @relation(fields: [userId], references: [id])
}
